---
import Layout from '../layouts/Layout.astro';
import LiveScores from '../components/LiveScores.astro';

const title = "Live Sports Scores & Fixtures | British IPTV";
const description = "Follow live sports scores, fixtures, and results in real-time. Don't miss a moment of the action with British IPTV's premium sports channels.";
---

<Layout title={title} description={description} lang="el">
	<!-- Hero Section -->
	<section class="relative pt-32 pb-16 overflow-hidden border-b border-white/5">
		<div class="absolute inset-0 z-0 bg-primary/5">
			<div class="absolute inset-0 bg-gradient-to-b from-bg-dark/80 via-bg-dark/90 to-bg-dark"></div>
		</div>

		<div class="max-container relative z-10 text-center max-w-3xl">
			<h1 class="text-4xl md:text-6xl font-black mb-6 tracking-tighter">
				Live <span class="text-gradient">Match Center</span>
			</h1>
			<p class="text-xl text-gray-400">
				Stay updated with live scores from the top leagues around the world. Watch all these matches live and in 4K with a British IPTV subscription.
			</p>
		</div>
	</section>

	<LiveScores />

    <!-- Promotional Banner -->
    <section class="py-12 bg-white/2">
        <div class="max-container max-w-4xl text-center">
            <div class="glass p-12 rounded-3xl border border-primary/20 bg-primary/5">
                <h3 class="text-3xl font-black mb-4">Want to watch these matches live?</h3>
                <p class="text-gray-300 text-lg mb-8">Get access to every single sports channel globally in true 4K without buffering.</p>
                <a href="/#section-pricing" class="btn-primary inline-flex px-8 py-4 text-lg font-bold">
                    View Premium Plans
                </a>
            </div>
        </div>
    </section>
</Layout>
