---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  const guides = [
    { slug: "setup-iptv-firestick", title: "How to setup IPTV on Firestick", content: "Setting up IPTV on a Firestick is incredibly easy. Simply install the Downloader app, fetch your preferred player like Smarters or Tivimate, and enter your iptv uk credentials." },
    { slug: "tivimate-best-settings", title: "Best Settings for Tivimate Premium", content: "To get the most out of Tivimate with iptv uk, ensure you adjust the buffer size to 'Large' in the playback settings and enable AFR (Auto Frame Rate) for smooth sports viewing." },
    { slug: "fix-iptv-buffering", title: "How to fix IPTV buffering issues", content: "If you experience buffering, first restart your router and device. Connecting via ethernet instead of WiFi dramatically improves stability. iptv uk's anti-freeze technology usually handles the rest." },
    { slug: "best-iptv-apps-smart-tv", title: "Top 5 IPTV Apps for Smart TVs (Samsung & LG)", content: "For Smart TVs running Tizen (Samsung) or WebOS (LG), the best apps include IBO Player, SET IPTV, and IPTV Smarters Pro. These apps are available directly in your TV's app store and seamlessly integrate with our service via a simple MAC address or M3U link setup." },
    { slug: "catchup-vod-guide", title: "The Ultimate Guide to Catch-up TV and VOD", content: "Catch-up TV allows you to rewind time up to 72 hours on major broadcast channels so you never miss a show. Our VOD (Video on Demand) library functions exactly like Major VOD Platforms or Major VOD Platforms, offering thousands of updated movies and series categorized by genre and IMDB rating." },
    { slug: "vpn-iptv-guide", title: "How to use a VPN with your IPTV Subscription", content: "While our service is highly secure, using a VPN can bypass ISP throttling during major sports events (like English Top-Flight matches). We highly recommend Surfshark or NordVPN. Simply connect to a UK or Netherlands server before launching your IPTV app." },
    { slug: "internet-speed-4k-iptv", title: "What internet speed do you need for 4K IPTV?", content: "For a flawless streaming experience, we recommend at least 15 Mbps for standard HD channels, 30 Mbps for Full HD (1080p), and a stable 50 Mbps connection for raw 4K UHD content and live sports without any frame drops." },
    { slug: "install-smarters-ios-appletv", title: "How to install Smarters Pro on Apple TV & iOS", content: "Apple users can easily access our service by downloading 'Smarters Player Lite' directly from the App Store. Once downloaded, select 'Login with Xtream Codes API', enter your username, password, and the portal URL provided in your welcome email." }
  ];
  return guides.map(guide => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const title = `${guide.title} | iptv uk Guides`;
const description = guide.content.substring(0, 150) + "...";

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": guide.title,
  "author": {
    "@type": "Organization",
    "name": "iptv uk"
  }
};
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <header class="sticky top-0 z-50 w-full bg-white/80 backdrop-blur-md border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
      <div class="flex-shrink-0">
        <a href="/" class="text-2xl font-bold text-secondary tracking-tight">iptv uk</a>
      </div>
      <div class="flex items-center gap-4">
        <a href="/guides" class="text-gray-600 hover:text-primary font-medium">Back to Guides</a>
        <a href="/#pricing" class="bg-primary text-white px-5 py-2 rounded-full font-semibold hover:bg-red-700 transition-all">Get Started</a>
      </div>
    </div>
  </header>

  <main class="flex-grow bg-gray-50 py-20">
    <article class="max-w-3xl mx-auto px-4">
      <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8 md:p-12">
        <h1 class="text-3xl md:text-4xl font-extrabold text-secondary mb-8">{guide.title}</h1>
        <div class="prose prose-lg text-gray-700 max-w-none">
          <p>{guide.content}</p>
        </div>
      </div>

      <!-- Permanent Promotional Banner -->
      <div class="mt-12 bg-gradient-to-r from-secondary to-[#001440] rounded-3xl p-8 text-center text-white shadow-xl shadow-blue-900/20">
        <h3 class="text-2xl font-bold mb-4">Tired of complicated setups and buffering?</h3>
        <p class="text-blue-100 mb-6 max-w-xl mx-auto">
          Switch to <strong class="text-white">iptv uk</strong> today for instant activation, 4K quality, and zero buffering on any device.
        </p>
        <a href="/#pricing" class="inline-block bg-primary hover:bg-red-700 text-white font-bold py-3 px-8 rounded-full transition-transform transform hover:scale-105">
          View Plans from £7
        </a>
      </div>
    </article>
  </main>
</Layout>
