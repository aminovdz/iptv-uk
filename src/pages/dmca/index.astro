---
import Layout from '../../layouts/Layout.astro';

const title = "DMCA Notice | iptv uk";
const description = "DMCA policy and disclaimer for iptv uk.";
---

<Layout title={title} description={description}>
  <header class="bg-secondary text-white py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">DMCA Notice & Disclaimer</h1>
    </div>
  </header>

  <main class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 prose prose-lg prose-blue">
      <p>This website is a review and informational blog. <strong>We do not host, control, provide, or sell</strong> any of the products, services, or content mentioned or reviewed on this site.</p>
      <p>All content, guides, and articles are provided strictly for <strong>educational and informational purposes</strong>.</p>
      <p>We take no responsibility for how users may choose to use the information contained herein. Users are responsible for complying with their local laws regarding streaming and copyright protection.</p>
      <p>If you believe that any content on this site infringes upon your copyright, please contact us via our contact form and we will promptly remove any offending links or references.</p>
    </div>
  </main>
</Layout>
