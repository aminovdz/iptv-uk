---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | iptv uk" description="Get in touch with the iptv uk support team. We're here to help you 24/7.">
  <header class="sticky top-0 z-50 w-full bg-white/80 backdrop-blur-md border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
      <a href="/" class="text-2xl font-bold text-secondary tracking-tight">iptv uk</a>
      <a href="/#pricing" class="bg-primary text-white px-5 py-2 rounded-full font-semibold hover:bg-red-700">Get Started</a>
    </div>
  </header>

  <main class="flex-grow bg-gray-50 py-20">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h1 class="text-4xl font-extrabold text-secondary mb-6">Contact Us</h1>
      <p class="text-gray-600 text-lg mb-12">Need help setting up or have a question about our premium IPTV service? We're available 24/7.</p>
      
      <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100">
        <form class="space-y-6 text-left" onsubmit="event.preventDefault(); alert('Message sent!');">
          <div>
            <label class="block text-gray-700 font-medium mb-2">Name</label>
            <input type="text" class="w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-primary focus:outline-none" required />
          </div>
          <div>
            <label class="block text-gray-700 font-medium mb-2">Email</label>
            <input type="email" class="w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-primary focus:outline-none" required />
          </div>
          <div>
            <label class="block text-gray-700 font-medium mb-2">Message</label>
            <textarea rows="5" class="w-full border border-gray-300 rounded-lg p-3 focus:ring-2 focus:ring-primary focus:outline-none" required></textarea>
          </div>
          <button type="submit" class="w-full bg-primary text-white font-bold py-3 rounded-lg hover:bg-red-700 transition-colors">Send Message</button>
        </form>
      </div>
    </div>
  </main>
</Layout>
