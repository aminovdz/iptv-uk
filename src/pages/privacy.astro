---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Privacy Policy | iptv uk" description="Privacy policy for iptv uk.">
  <header class="sticky top-0 z-50 w-full bg-white/80 backdrop-blur-md border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
      <a href="/" class="text-2xl font-bold text-secondary tracking-tight">iptv uk</a>
    </div>
  </header>

  <main class="flex-grow bg-white py-20">
    <div class="max-w-3xl mx-auto px-4 prose text-gray-700">
      <h1 class="text-4xl font-extrabold text-secondary mb-8">Privacy Policy</h1>
      <p>Last updated: {new Date().toLocaleDateString()}</p>
      
      <h2>1. Information Collection</h2>
      <p>At iptv uk, we collect minimal information necessary to provide you with our streaming service, such as your email address for account delivery and support communications.</p>
      
      <h2>2. Data Usage</h2>
      <p>Your data is used strictly for account management, billing, and technical support. We do not sell your personal information to third parties.</p>

      <h2>3. Security</h2>
      <p>We implement industry-standard security measures to ensure your data is protected against unauthorized access.</p>
    </div>
  </main>
</Layout>
