---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404: Page Not Found | iptv uk" description="Oops! The page you are looking for does not exist. Return to iptv uk for premium streaming.">
  <header class="sticky top-0 z-50 w-full bg-white/80 backdrop-blur-md border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
      <a href="/" class="text-2xl font-bold text-secondary tracking-tight">iptv uk</a>
    </div>
  </header>

  <main class="flex-grow bg-gray-50 flex items-center justify-center py-32">
    <div class="max-w-xl mx-auto px-4 text-center">
      <h1 class="text-9xl font-extrabold text-primary mb-6">404</h1>
      <h2 class="text-3xl font-bold text-secondary mb-4">Page Not Found</h2>
      <p class="text-gray-600 text-lg mb-8">
        We can't seem to find the page you're looking for. It might have been moved or no longer exists.
      </p>
      <a href="/" class="inline-block bg-primary text-white font-bold py-3 px-8 rounded-full hover:bg-red-700 transition-colors shadow-lg shadow-primary/30">
        Return to Homepage
      </a>
    </div>
  </main>
</Layout>
